[Unit]
Description=Glitch Web Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=glitch
Group=glitch
ExecStart=/usr/local/bin/glitch -port 8765 -dash-port 8766
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
