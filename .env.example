# Glitch Server Environment Configuration
# Copy to .env and adjust values as needed.
# The server auto-loads .env on startup (no need to manually source it).
# Explicit env vars and CLI flags always take precedence over .env values.

# Admin panel password (required for dashboard access on :8766)
GLITCH_ADMIN_PASSWORD=admin

# PostgreSQL connection URL (optional — without this, data is lost on restart)
# To start a local PostgreSQL container: make db-up
GLITCH_DB_URL=postgres://glitch:glitch@localhost:5432/glitch?sslmode=disable
