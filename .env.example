# Glitch Server Environment Configuration
# Copy to .env and adjust values as needed.
# The server auto-loads .env on startup (no need to manually source it).
# Explicit env vars and CLI flags always take precedence over .env values.

# Admin panel password (required for dashboard access on :8766)
# Password changes via the admin UI are persisted to the database.
# On restart, the DB password takes priority over this value.
GLITCH_ADMIN_PASSWORD=admin

# Set to 1 to force-reset the admin password from GLITCH_ADMIN_PASSWORD above,
# even if the database has a different password stored. Useful for password recovery.
# Remove or set to 0 after resetting.
# PASSWORD_RESET_FROM_ENV=1

# PostgreSQL connection URL (optional — without this, data is lost on restart)
# To start a local PostgreSQL container: make db-up
GLITCH_DB_URL=postgres://glitch:glitch@localhost:5432/glitch?sslmode=disable

# Secret path for internal health endpoint (optional — auto-generated if not set).
# The real health check is at /_internal/<secret>/healthz.
# All public health endpoints (/health, /health/live, /actuator, etc.) are
# emulated and subject to error injection like any other endpoint.
# GLITCH_HEALTH_SECRET=my-secret-uuid

# Sentry error tracking (optional — disabled if not set)
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id

# TLS/HTTPS configuration (optional — self-signed cert auto-generated if not set)
# The TLS listener runs on port 8767 by default (configurable with -tls-port flag).
# GLITCH_TLS_CERT=/path/to/cert.pem
# GLITCH_TLS_KEY=/path/to/key.pem
